{
  "expo": {
    "name": "InventarioYa",
    "slug": "inventarioya-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iya.png",
    "scheme": "inventarioyafrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.inventarioya.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/iya.png",
        "backgroundImage": "./assets/images/iya.png",
        "monochromeImage": "./assets/images/iya.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/iya.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b0ab4a43-d48e-40f7-9c72-1c659dc71cc1",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0ab4a43-d48e-40f7-9c72-1c659dc71cc1"
      }
    },
    "owner": "cesarcode"
  }
}
